---
import "../styles/global.css";
import type { ComponentChildren } from "preact";

interface Props {
  title: string;
  description?: string;
  children?: ComponentChildren;
}

const {
  title,
  description = "Villa -- Full Stack Developer | React, Node.js, TypeScript | Passionate about building scalable web applications and crafting seamless user experiences.",
  children,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0f0a" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin="anonymous"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="bg-terminal-bg text-gray-100 overflow-x-hidden">
    <slot>{children}</slot>
  </body>
</html>
